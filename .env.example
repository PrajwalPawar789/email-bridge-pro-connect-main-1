SEARCH_PROSPECTS_SOURCE="prospects"
SEARCH_COMPANIES_SOURCE="companies"
SEARCH_COMPANIES_DERIVE_FROM_PROSPECTS=false
SEARCH_PROSPECT_COMPANY_SEARCH_COLUMN="company"
