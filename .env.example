# Optional: automatically attach custom domains to your Vercel project
VERCEL_TOKEN=""
VERCEL_PROJECT_ID_OR_NAME="email-bridge-pro-connect-main"
VERCEL_TEAM_ID="team_857yNB4PRluBsvXTp3C4RiIc"
VERCEL_TEAM_SLUG="prajwalpawar789s-projects"

# Reply/Reply-All behavior
MAILBOX_REPLY_INCLUDE_ORIGINAL_ATTACHMENTS=false
MAILBOX_REPLY_BLOCK_NOREPLY=false
MAILBOX_REPLY_NOREPLY_REGEX="(^|[+._-])no-?reply|do-?not-?reply"
MAILBOX_REPLY_REFERENCES_LIMIT=20
MAILBOX_REPLY_REFERENCES_CHAR_LIMIT=1900

