# Supabase project credentials
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_PROJECT_REF="your-project-ref"
SUPABASE_ACCESS_TOKEN="sbp_your_personal_access_token"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
VITE_SUPABASE_DEV_PROXY=true
VITE_SUPABASE_DEV_PROXY_URL=""
VITE_SUPABASE_DNS_SERVERS="1.1.1.1,8.8.8.8"
# App URL used by Supabase Auth emails and edge functions like workspace-invite-member
APP_URL="http://localhost:8080"
SITE_URL="http://localhost:8080"

# Mailbox sync server config
MAILBOX_SERVER_PORT=8787
MAILBOX_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:8080,https://onrenderimaptest-yisx.onrender.com/"
MAILBOX_BYPASS_AUTH=true
MAILBOX_ADMIN_SECRET="your-admin-secret"
# Optional: have check-email-replies call sync-mailbox API before processing
MAILBOX_SYNC_URL="https://onrenderimaptest-yisx.onrender.com/sync-mailbox"
MAILBOX_SYNC_BEFORE_REPLY_CHECK=true
MAILBOX_SYNC_AUTH_TOKEN=""
MAILBOX_SYNC_TIMEOUT_MS=90000
MAILBOX_SYNC_LIMIT=50
MAILBOX_SYNC_STRICT=false
# Optional: have Supabase check-email-replies delegate to Render mailbox server
MAILBOX_REPLY_CHECK_URL="https://onrenderimaptest-yisx.onrender.com/check-email-replies"
MAILBOX_REPLY_CHECK_SECRET="your-admin-secret"
MAILBOX_REPLY_CHECK_TIMEOUT_MS=90000
MAILBOX_REPLY_CHECK_STRICT=false
# Automatic reply/bounce checks (server)
MAILBOX_AUTO_CHECK_REPLIES=false
MAILBOX_AUTO_CHECK_INTERVAL_MINUTES=10
MAILBOX_AUTO_CHECK_LOOKBACK_DAYS=7
MAILBOX_AUTO_CHECK_USE_DB_SCAN=false
MAILBOX_AUTO_CHECK_CONFIG_ID=""
# Automatic mailbox sync (server)
MAILBOX_AUTO_SYNC_MAILBOXES=false
MAILBOX_AUTO_SYNC_INTERVAL_MINUTES=10
MAILBOX_AUTO_SYNC_LIMIT=50
MAILBOX_AUTO_SYNC_CONFIG_ID=""
MAILBOX_LOG_SYNC_SAMPLES=false
AUTOMATION_RUNNER_HEARTBEAT=true
AUTOMATION_RUNNER_INTERVAL_SECONDS=30
AUTOMATION_RUNNER_MAX_WORKFLOWS=40
CRM_FRONTEND_URL="http://localhost:8080"
CRM_OAUTH_REDIRECT_URI="http://localhost:8080/dashboard?tab=integrations"

# Frontend env vars (Vite)
VITE_MAILBOX_SYNC_URL="https://onrenderimaptest-yisx.onrender.com/sync-mailbox"
VITE_MAILBOX_API_URL="https://onrenderimaptest-yisx.onrender.com"
VITE_CRM_API_BASE_URL="https://onrenderimaptest-yisx.onrender.com"
# CRM connection endpoints (use mailbox server)
VITE_CRM_BACKEND_URL="https://onrenderimaptest-yisx.onrender.com"
VITE_API_BASE_URL=""
# Prospect search shard secrets for the catalog-search edge function
SEARCH_BYPASS_AUTH=false
SHARD_COUNT=1
# For deployed edge functions, use the SEARCH_SHARD_* names below.
# Supabase reserves custom secret names starting with SUPABASE_.
SEARCH_SHARD_URL_1="https://your-shard-1.supabase.co"
SEARCH_SHARD_SERVICE_ROLE_KEY_1="your-shard-1-service-role-key"
SEARCH_SHARD_ANON_KEY_1="your-shard-1-anon-key"
# Local tooling can still read the legacy numbered names if you use them in local env files.
SUPABASE_URL_1="https://your-shard-1.supabase.co"
SUPABASE_SERVICE_ROLE_KEY_1="your-shard-1-service-role-key"
SUPABASE_ANON_KEY_1="your-shard-1-anon-key"
